# MongoDB Atlas connection string (optional).
# If set, the app persists data permanently in MongoDB.
# If left empty/unset, the app uses an in-memory store (data resets on restart).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/brightstar

# Secret used to sign JWT auth tokens
JWT_SECRET=bright_star_secret

# Port for local development
PORT=3000
